# Public/runtime configuration. Copy to /etc/matmix/matmix.env with mode 0640.
NODE_ENV=production
PORT=3000
SESSION_DB_PATH=/var/lib/matmix/sessions.db
MATMIX_DB_PATH=/var/lib/matmix/matmix.db
PRODUCT_UPLOADS_PATH=/var/lib/matmix/uploads/products
BACKUP_ROOT_PATH=/var/backups/matmix
BACKUP_RETENTION_COUNT=14
BACKUP_MAX_AGE_HOURS=36
APP_RUNTIME_LOCK_PATH=/var/lib/matmix/matmix-runtime.lock
MIN_FREE_DISK_MB=2048
PUBLIC_BASE_URL=https://example.invalid
SEO_ALLOW_INDEXING=false
SITE_NAME=MatMix
DEFAULT_OG_IMAGE=/img/logo-burgundy.png
CORS_ALLOWED_ORIGINS=https://example.invalid
TRUST_PROXY=1
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=5
SESSION_TTL_MS=28800000
SHUTDOWN_TIMEOUT_MS=30000

# Secret: generate independently; never commit the real value.
SESSION_SECRET=[GENERATE AT LEAST 48 RANDOM CHARACTERS]

# Legal public values and approved document versions. See docs/legal-readiness.md.
LEGAL_BUSINESS_NAME=[APPROVED VALUE]
LEGAL_ENTITY_FORM=[APPROVED VALUE]
LEGAL_REGISTRATION_ID=[APPROVED VALUE]
LEGAL_TAX_ID=[APPROVED VALUE]
LEGAL_ADDRESS=[APPROVED VALUE]
LEGAL_POSTAL_ADDRESS=[APPROVED VALUE]
PUBLIC_PHONE=[APPROVED VALUE]
PUBLIC_EMAIL=[APPROVED VALUE]
PUBLIC_WORKING_HOURS=[APPROVED VALUE]
LEGAL_JURISDICTION=[APPROVED VALUE]
LEGAL_PROCESSORS=[APPROVED VALUE]
LEGAL_EFFECTIVE_DATE=[APPROVED VALUE]
PRIVACY_POLICY_VERSION=[APPROVED VERSION]
TERMS_VERSION=[APPROVED VERSION]
CUSTOMER_DATA_RETENTION=[APPROVED VALUE]
ORDER_DATA_RETENTION=[APPROVED VALUE]
LOG_RETENTION=[APPROVED VALUE]
BACKUP_RETENTION=[APPROVED VALUE]
# The remaining approved delivery/payment/returns variables are listed in docs/legal-readiness.md.
