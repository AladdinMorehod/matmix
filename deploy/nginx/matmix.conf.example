limit_req_zone $binary_remote_addr zone=matmix_login:10m rate=10r/m;

server {
    listen 80;
    listen [::]:80;
    server_name example.invalid;
    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name example.invalid;
    ssl_certificate /etc/letsencrypt/live/example.invalid/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.invalid/privkey.pem;
    server_tokens off;
    client_max_body_size 12m;
    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml image/svg+xml;

    location ~ /\. { deny all; }
    location = /api/auth/login { limit_req zone=matmix_login burst=5 nodelay; proxy_pass http://127.0.0.1:3000; include proxy_params; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto $scheme; proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; proxy_set_header X-Real-IP $remote_addr; proxy_read_timeout 30s; }
    location ~ ^/(css|js|img|uploads/products)/ { proxy_pass http://127.0.0.1:3000; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto $scheme; proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; proxy_set_header X-Real-IP $remote_addr; proxy_read_timeout 30s; }
    location / { proxy_pass http://127.0.0.1:3000; proxy_http_version 1.1; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto $scheme; proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; proxy_set_header X-Real-IP $remote_addr; proxy_read_timeout 60s; proxy_send_timeout 60s; add_header Cache-Control "no-store" always; }
}
