{
  "name": "matmix",
  "version": "1.0.0",
  "description": "MatMix site and order CRM backend",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "import:products:reset": "node backend/scripts/reset-and-import-products.js",
    "catalog:migrate-mat": "node backend/scripts/migrate-mat-external-ids.js",
    "catalog:resolve-mat": "node backend/scripts/resolve-mat-external-ids.js",
    "catalog:migrate-structure-codes": "node backend/scripts/migrate-structure-codes.js",
    "catalog:cleanup-structure": "node backend/scripts/cleanup-catalog-structure.js",
    "catalog:fixes": "node backend/scripts/apply-catalog-fixes.js",
    "fix:plywood-groups": "npm run catalog:fixes",
    "database:migrate": "node backend/scripts/migrate-database.js",
    "database:health": "node backend/scripts/check-database-health.js",
    "test:database-integrity": "node backend/scripts/test-database-integrity.js",
    "images:optimize": "node backend/scripts/optimize-product-images.js",
    "test:product-images": "node backend/scripts/test-product-images.js && node backend/scripts/test-product-image-api.js",
    "test:seo": "node backend/scripts/test-seo.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "sharp": "^0.35.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
